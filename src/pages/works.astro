---
	import Layout from '@layouts/layout.astro'
  import WorkList from '@components/works/WorkList.svelte'
  import { workCategoriesText, workCategoriesImage, workCategoriesMusic } from '@lib/constants'

  const { supabase, user } = Astro.locals
  const activeTab = Astro.url.searchParams.get('tab') || 'articles'
  const tag = Astro.url.searchParams.get('tag') || ''
  const category = Astro.url.searchParams.get('category') || ''

  const page = parseInt(Astro.url.searchParams.get('page') || '0')
  const limit = 20

  const typeMap = { articles: 'text', images: 'image', music: 'audio' }
  const categoryMap = {
    articles: workCategoriesText,
    images: workCategoriesImage,
    music: workCategoriesMusic
  }
  const allowedCategories = categoryMap[activeTab] || []
  const activeCategory = allowedCategories.some((item) => item.value === category) ? category : ''
  let query = supabase.from('work_list').select('*', { count: 'exact' }).match({ published: true, type: typeMap[activeTab] })
  if (tag) { query = query.contains('tags', [tag]) }
  if (activeCategory) { query = query.eq('category', activeCategory) }
  const { data: works, count, error } = await query.range(page * limit, page * limit + limit - 1)
  const maxPage = Math.ceil(count / limit) - 1
  if (error) { console.error(error) }
---

<Layout title='Tvorba'>
  <WorkList {user} {works} {activeTab} {tag} category={activeCategory} {page} {maxPage} showHeadline client:load />
</Layout>
